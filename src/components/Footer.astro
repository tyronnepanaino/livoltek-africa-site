---
/**
 * FOOTER — Fully static Astro component
 * ========================================
 *
 * MIGRATION NOTE:
 *   Copy the full content from your existing Footer.tsx.
 *   Replace all <Link to="..."> with plain <a href="...">.
 *   This is a minimal scaffold — flesh it out with your real footer content.
 */
import { companyInfo } from '../lib/mockData';

const livoltekLogo = '/images/livoltek-logo.webp';

const quickLinks = [
  { label: 'Products', href: '/products' },
  { label: 'Solutions', href: '/solutions' },
  { label: 'Insights', href: '/insights' },
  { label: 'Resources', href: '/resources' },
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Request a Quote', href: '/contact/quote-request' },
];

const productLinks = [
  { label: 'Solar Inverters', href: '/products/category/solar-inverters' },
  { label: 'Energy Storage', href: '/products/category/energy-storage' },
  { label: 'Solar Panels', href: '/products/category/solar-panels' },
  { label: 'EV Charging', href: '/products/category/ev-charging' },
  { label: 'Monitoring Systems', href: '/products/category/monitoring-systems' },
];
---

<footer class="bg-[#0C2340] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      {/* Brand */}
      <div>
        <a href="/" aria-label="Livoltek Africa Home">
          <img src={livoltekLogo} alt="Livoltek Africa" class="h-10 w-auto mb-4 brightness-0 invert" />
        </a>
        <p class="text-gray-300 mt-2" style="font-size: 0.875rem; line-height: 1.7;">
          {companyInfo.tagline}
        </p>
      </div>

      {/* Quick Links */}
      <div>
        <h3 class="text-white mb-4" style="font-size: 1rem; font-weight: 600;">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-300 hover:text-[#009BFF] transition-colors"
                style="font-size: 0.875rem;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Products */}
      <div>
        <h3 class="text-white mb-4" style="font-size: 1rem; font-weight: 600;">Products</h3>
        <ul class="space-y-2">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-300 hover:text-[#009BFF] transition-colors"
                style="font-size: 0.875rem;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h3 class="text-white mb-4" style="font-size: 1rem; font-weight: 600;">Contact Us</h3>
        <ul class="space-y-3">
          <li>
            <a
              href={`tel:${companyInfo.phone}`}
              class="text-gray-300 hover:text-[#009BFF] transition-colors"
              style="font-size: 0.875rem;"
            >
              {companyInfo.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${companyInfo.email}`}
              class="text-gray-300 hover:text-[#009BFF] transition-colors"
              style="font-size: 0.875rem;"
            >
              {companyInfo.email}
            </a>
          </li>
          <li class="text-gray-300" style="font-size: 0.875rem;">
            {companyInfo.address.formatted}
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400" style="font-size: 0.8125rem;">
        &copy; {new Date().getFullYear()} {companyInfo.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        {companyInfo.social.linkedin && (
          <a href={companyInfo.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#009BFF] transition-colors" aria-label="LinkedIn">
            LinkedIn
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
