---
/**
 * CONTACT PAGE — Full conversion from ContactPage.tsx
 * Static shell with contact info + React island for the form.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { companyInfo } from '../../lib/mockData';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../../lib/schema';
import ContactForm from '../../components/ContactForm.tsx';

const jsonLd = [
  buildLocalBusinessSchema(),
  buildBreadcrumbSchema([
    { name: 'Home', url: `${companyInfo.url}/` },
    { name: 'Contact', url: `${companyInfo.url}/contact` },
  ]),
];
---

<BaseLayout
  title="Contact Us | Get a Solar Energy Quote | Livoltek Africa"
  description="Contact Livoltek Africa for commercial and industrial solar energy solutions. Get a free consultation and customized proposal for your business. Call +27 67 781 4887."
  keywords="contact Livoltek Africa, solar quote, commercial solar consultation, industrial solar inquiry, solar energy proposal"
  canonicalPath="/contact"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="bg-[#0C2340] py-14 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-white/50" style="font-size: 0.8125rem;">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 5l7 7-7 7"></path></svg></li>
          <li class="text-white">Contact</li>
        </ol>
      </nav>
      <h1 class="text-white mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; line-height: 1.2;">
        Get in Touch
      </h1>
      <p class="text-white/70 max-w-2xl" style="font-size: 1.125rem; line-height: 1.7;">
        Ready to power your business with solar? Contact us for a free consultation and customized energy proposal.
      </p>
    </div>
  </section>

  {/* Contact Content */}
  <section class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {/* Contact Info (fully static) */}
        <div class="lg:col-span-1">
          <h2 class="text-[#0C2340] mb-6" style="font-size: 1.375rem; font-weight: 700;">Contact Information</h2>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-[#E6F3FF] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#009BFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <h3 class="text-[#0C2340] mb-1" style="font-size: 0.9375rem; font-weight: 600;">Head Office</h3>
                <address class="text-[#5A6A7E] not-italic" style="font-size: 0.875rem; line-height: 1.6;">
                  82 Roan Crescent, Corporate Park North,<br />
                  Midrand, Johannesburg, Gauteng,<br />
                  1685, South Africa
                </address>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-[#E6F3FF] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#009BFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <h3 class="text-[#0C2340] mb-1" style="font-size: 0.9375rem; font-weight: 600;">Phone</h3>
                <a href={`tel:${companyInfo.phone}`} class="text-[#5A6A7E] hover:text-[#009BFF] transition-colors block" style="font-size: 0.875rem;">
                  {companyInfo.phone}
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-[#E8FAF0] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#25D366]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
              </div>
              <div>
                <h3 class="text-[#0C2340] mb-1" style="font-size: 0.9375rem; font-weight: 600;">WhatsApp</h3>
                <a
                  href={`https://wa.me/${companyInfo.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent("Hi Livoltek Africa, I'd like to inquire about your solar solutions.")}`}
                  target="_blank" rel="noopener noreferrer"
                  class="text-[#5A6A7E] hover:text-[#25D366] transition-colors block" style="font-size: 0.875rem;"
                >
                  {companyInfo.whatsapp}
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-[#E6F3FF] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#009BFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <h3 class="text-[#0C2340] mb-1" style="font-size: 0.9375rem; font-weight: 600;">Email</h3>
                <a href={`mailto:${companyInfo.email}`} class="text-[#5A6A7E] hover:text-[#009BFF] transition-colors block" style="font-size: 0.875rem;">
                  {companyInfo.email}
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-[#E6F3FF] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#009BFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div>
                <h3 class="text-[#0C2340] mb-1" style="font-size: 0.9375rem; font-weight: 600;">Business Hours</h3>
                <p class="text-[#5A6A7E]" style="font-size: 0.875rem; line-height: 1.6;">Monday - Friday: 08:30 - 17:00<br />Saturday - Sunday: Closed</p>
              </div>
            </div>
          </div>

          {/* Social Links */}
          <div class="mt-8 pt-6 border-t border-gray-200">
            <h3 class="text-[#0C2340] mb-4" style="font-size: 0.9375rem; font-weight: 600;">Follow Us</h3>
            <div class="flex gap-3">
              {[
                { label: 'LinkedIn', href: companyInfo.social.linkedin },
                { label: 'Twitter', href: companyInfo.social.twitter },
                { label: 'Facebook', href: companyInfo.social.facebook },
                { label: 'YouTube', href: companyInfo.social.youtube },
              ].map(s => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-lg bg-[#F5F7FA] hover:bg-[#009BFF] hover:text-white flex items-center justify-center text-[#5A6A7E] transition-colors"
                  aria-label={`Follow us on ${s.label}`}
                  style="font-size: 0.75rem; font-weight: 600;"
                >
                  {s.label[0]}
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* Contact Form (React island — hydrated when visible) */}
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl p-6 md:p-8 shadow-sm border border-gray-100">
            <h2 class="text-[#0C2340] mb-2" style="font-size: 1.375rem; font-weight: 700;">Get in Contact</h2>
            <p class="text-[#5A6A7E] mb-6" style="font-size: 0.9375rem;">
              Fill out the form below and our team will respond within 24 business hours.
            </p>
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
