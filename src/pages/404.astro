---
/**
 * 404 PAGE — Full conversion from NotFoundPage.tsx
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Livoltek Africa"
  description="The page you are looking for does not exist. Please navigate to our homepage or use the links below."
  noindex={true}
>
  <div class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center max-w-lg px-4">
      <div class="text-[#009BFF] mb-4" style="font-size: 6rem; font-weight: 800; line-height: 1;">404</div>
      <h1 class="text-[#0C2340] mb-3" style="font-size: 1.75rem; font-weight: 700;">Page Not Found</h1>
      <p class="text-[#5A6A7E] mb-8" style="font-size: 1.0625rem; line-height: 1.7;">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
        <a href="/" class="inline-flex items-center gap-2 bg-[#009BFF] hover:bg-[#0080D9] text-white px-6 py-3 rounded-lg transition-colors" style="font-weight: 600;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Go to Homepage
        </a>
        <a href="/products" class="inline-flex items-center gap-2 bg-[#F5F7FA] hover:bg-gray-100 text-[#0C2340] px-6 py-3 rounded-lg transition-colors" style="font-weight: 600;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          Browse Products
        </a>
      </div>

      {/* Quick Links */}
      <div class="border-t border-gray-200 pt-8">
        <p class="text-[#5A6A7E] mb-4" style="font-size: 0.875rem; font-weight: 500;">Or try one of these popular pages:</p>
        <div class="grid grid-cols-2 gap-2">
          {[
            { label: 'Solar Inverters', path: '/products/category/solar-inverters' },
            { label: 'Energy Storage', path: '/products/category/energy-storage' },
            { label: 'Our Solutions', path: '/solutions' },
            { label: 'Industry Insights', path: '/insights' },
            { label: 'About Us', path: '/about' },
            { label: 'Contact Us', path: '/contact' },
          ].map(link => (
            <a href={link.path} class="text-[#0C2340] hover:text-[#009BFF] transition-colors flex items-center gap-1 py-1.5" style="font-size: 0.875rem;">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      {/* CTA */}
      <div class="mt-8 bg-[#E6F3FF] rounded-xl p-5">
        <p class="text-[#0C2340] mb-3" style="font-size: 0.9375rem; font-weight: 600;">
          Looking for a solar energy solution?
        </p>
        <a href="/contact/quote-request" class="inline-flex items-center gap-2 bg-[#009BFF] hover:bg-[#0080D9] text-white px-5 py-2.5 rounded-lg transition-colors" style="font-size: 0.875rem; font-weight: 600;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
          Request a Free Quote
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
